FROM postgres:17-alpine

RUN apk add --no-cache aws-cli bash coreutils openssl tzdata

COPY deploy/backup-postgres.sh /usr/local/bin/backup-postgres.sh
COPY deploy/restore-postgres-backup.sh /usr/local/bin/restore-postgres-backup.sh

RUN sed -i 's/\r$//' /usr/local/bin/backup-postgres.sh /usr/local/bin/restore-postgres-backup.sh \
    && chmod +x /usr/local/bin/backup-postgres.sh /usr/local/bin/restore-postgres-backup.sh

ENTRYPOINT ["/usr/bin/env", "bash", "/usr/local/bin/backup-postgres.sh"]
